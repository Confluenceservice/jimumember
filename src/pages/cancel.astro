---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Checkout cancelled">
  <section class="card">
    <h1 class="headline">Checkout cancelled</h1>
    <p class="sub">
      No payment was taken. You can start again when ready.
    </p>
    <p style="margin-top: 1rem;">
      <a href="/" style="color: var(--accent); font-weight: 600;">Back to membership plans</a>
    </p>
  </section>
</BaseLayout>
